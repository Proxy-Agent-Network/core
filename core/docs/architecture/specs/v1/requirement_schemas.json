{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PAN Mission Requirement Schemas",
  "description": "JSON Schemas for validating AV Fleet-submitted UDS dispatch requirements.",
  "definitions": {
    "optical_reclamation": {
      "type": "object",
      "properties": {
        "uds_fault_code": {
          "type": "string",
          "enum": [
            "LIDAR_MUD_OCCLUSION",
            "OPTICAL_LENS_OBSTRUCTED",
            "RADAR_FASCIA_BLOCKED"
          ]
        },
        "target_sensor_location": {
          "type": "string",
          "description": "Physical location on the AV (e.g., 'FRONT_LEFT_DOME')"
        },
        "requires_hp_potion": {
          "type": "boolean",
          "default": true,
          "description": "Indicates if the Agent must use the proprietary 4-Phase ORP solvent kit."
        },
        "timeout_seconds": {
          "type": "integer",
          "default": 900,
          "description": "15-minute standard SLA"
        }
      },
      "required": [
        "uds_fault_code",
        "target_sensor_location"
      ]
    },
    "cabin_secure": {
      "type": "object",
      "properties": {
        "uds_fault_code": {
          "type": "string",
          "enum": [
            "CABIN_DOOR_AJAR",
            "TRUNK_NOT_LATCHED",
            "FRUNK_UNSECURED"
          ]
        },
        "target_closure": {
          "type": "string",
          "description": "Specific door or latch to inspect (e.g., 'PASSENGER_REAR')"
        },
        "cabin_emergency_override": {
          "type": "boolean",
          "default": false,
          "description": "If true, Agent is authorized to break cabin prohibition rules to assist a passenger."
        },
        "timeout_seconds": {
          "type": "integer",
          "default": 900
        }
      },
      "required": [
        "uds_fault_code",
        "target_closure"
      ]
    },
    "perimeter_clear": {
      "type": "object",
      "properties": {
        "uds_fault_code": {
          "type": "string",
          "enum": [
            "PERIMETER_VANDALISM",
            "PATH_OBSTRUCTED_DEBRIS"
          ]
        },
        "obstacle_description": {
          "type": "string",
          "description": "Context injection from Fleet API describing the object"
        },
        "estimated_weight_kg": {
          "type": "number",
          "maximum": 25,
          "description": "Agents are not authorized to lift hazardous items exceeding 25kg. Escalate to tow if heavier."
        },
        "timeout_seconds": {
          "type": "integer",
          "default": 900
        }
      },
      "required": [
        "uds_fault_code"
      ]
    },
    "scene_secure": {
      "type": "object",
      "properties": {
        "uds_fault_code": {
          "type": "string",
          "enum": [
            "KINETIC_COLLISION",
            "CRITICAL_HARDWARE_FAILURE",
            "FLAT_TIRE"
          ]
        },
        "tow_dispatched": {
          "type": "boolean",
          "description": "Confirms the Fleet has initiated a heavy-duty tow retrieval."
        },
        "hazard_lights_active": {
          "type": "boolean"
        },
        "timeout_seconds": {
          "type": "integer",
          "default": 7200,
          "description": "Extended timeout (2 hours) for prolonged Tow Truck wait times."
        }
      },
      "required": [
        "uds_fault_code",
        "tow_dispatched"
      ]
    }
  }
}